{
  "name": "role-sdk",
  "version": "0.1.0",
  "description": "Official TypeScript SDK for Role APIs",
  "license": "MIT",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/role-co/role-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/role-co/role-sdk/issues"
  },
  "homepage": "https://github.com/role-co/role-sdk#readme",
  "keywords": [
    "role",
    "sdk",
    "api",
    "typescript",
    "client",
    "rest",
    "grpc"
  ],
  "author": "Role Technologies, Inc. <hello@role.com>",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "contracts:grpc:generate:dart": "pnpm contracts:grpc:sync && node ./scripts/grpc/generate-dart-grpc-sdk.mjs",
    "contracts:grpc:sync": "node ./scripts/grpc/sync-role-node-proto.mjs",
    "contracts:openapi:build-dart-openapi": "node ./scripts/openapi/build-dart-openapi.mjs",
    "contracts:openapi:build-spec": "node ./scripts/openapi/build-sdk-spec.mjs",
    "contracts:openapi:sync": "node ./scripts/openapi/sync-role-node-openapi.mjs",
    "contracts:openapi:check": "node ./scripts/openapi/check-openapi-artifact.mjs",
    "contracts:openapi:check:required": "node ./scripts/openapi/check-openapi-artifact.mjs --required --strict",
    "contracts:openapi:generate:dart-rest": "pnpm contracts:openapi:build-dart-openapi && node ./scripts/openapi/generate-dart-sdk.mjs",
    "contracts:openapi:prepare": "pnpm contracts:openapi:sync && pnpm contracts:openapi:check && pnpm contracts:openapi:build-spec",
    "contracts:openapi:remote:preflight": "node ./scripts/openapi/remote-preflight.mjs",
    "contracts:openapi:remote:generate-and-pull:dart-rest": "pnpm contracts:openapi:remote:preflight && pnpm contracts:openapi:remote:generate:dart-rest && pnpm contracts:openapi:remote:pull:dart-rest",
    "contracts:openapi:remote:generate:dart-rest": "node ./scripts/openapi/remote-generate-dart-sdk.mjs",
    "contracts:openapi:remote:pull:dart-rest": "node ./scripts/openapi/remote-pull-dart-sdk.mjs",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "lint": "eslint .",
    "release": "semantic-release",
    "test": "vitest run",
    "test:contracts": "vitest run --config vitest.contract.config.ts",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.6",
    "@semantic-release/npm": "^12.0.2",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@types/node": "^24.8.1",
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "@typescript-eslint/parser": "^8.46.1",
    "eslint": "^9.37.0",
    "prettier": "^3.6.2",
    "semantic-release": "^25.0.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
