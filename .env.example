# OpenAPI generation (local)
OPENAPI_GENERATOR_IMAGE=openapitools/openapi-generator-cli:v7.7.0
DART_REST_SDK_OUTPUT_DIR=generated/dart/role_rest_sdk
ROLE_NODE_OPENAPI_PATH=/absolute/path/to/role-node/contracts/generated/openapi.json
OPENAPI_DOCKER_VOLUME_OPTIONS=

# gRPC generation (local)
ROLE_NODE_PROTO_DIR=/absolute/path/to/role-node/proto
DART_GRPC_SDK_OUTPUT_DIR=generated/dart/role_grpc_sdk

# Remote generation + pull
REMOTE_SSH_TARGET=user@remote-host
REMOTE_ROLE_SDK_PATH=/absolute/path/to/role-sdk
REMOTE_DART_REST_SDK_OUTPUT_DIR=generated/dart/role_rest_sdk
LOCAL_DART_REST_SDK_OUTPUT_DIR=generated/dart/role_rest_sdk
REMOTE_SYNC_KEEP_CONFIG=true

# Optional extra CLI flags
REMOTE_SSH_OPTS=-p 22
REMOTE_RSYNC_OPTS=--progress
